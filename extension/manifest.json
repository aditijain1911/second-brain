{
  "manifest_version": 3,
  "name": "Second Brain",
  "version": "1.0",
  "permissions": ["activeTab", "storage", "scripting"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
  
}